FROM python:3.12-slim

WORKDIR /app

COPY requirements.txt .
RUN pip install --no-cache-dir \
    httpx \
    fastapi \
    uvicorn \
    python-dotenv \
    pytest \
    pytest-asyncio

COPY . .

ENV TELEGRAM_BOT_TOKEN=test:token
ENV ALLOWED_USER_ID=12345678
ENV CLI_RUNNER=generic
ENV CLI_COMMAND=echo

CMD ["pytest", "tests/", "-v", "--tb=short"]
